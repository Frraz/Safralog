# =============================================================================
# SafraLog — .gitignore
# =============================================================================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
*.pyc
*.pyo
.eggs/
dist/
build/

# =============================================================================
# Django
# =============================================================================
local_settings.py
db.sqlite3
db.sqlite3-journal

# Arquivos de mídia (uploads de usuários — gerenciado por S3 em produção)
media/

# Estáticos coletados (gerados por collectstatic — não versionar)
staticfiles/

# Logs
*.log

# =============================================================================
# Variáveis de ambiente
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Ambientes virtuais Python
# =============================================================================
.venv
venv/
env/
ENV/

# =============================================================================
# Frontend — gerados pelo build (npm run build)
# =============================================================================

# CSS compilado pelo Tailwind
static/css/dist/

# JS de vendors copiados pelo npm run vendor
static/js/vendor/

# Node
node_modules/
npm-debug.log*
yarn-error.log*
.npm/

# =============================================================================
# Docker
# =============================================================================
.docker/

# =============================================================================
# Celery
# =============================================================================
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid

# =============================================================================
# Testes e cobertura
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# =============================================================================
# Type checking e linting
# =============================================================================
.mypy_cache/
.ruff_cache/
.pyright/

# =============================================================================
# IDEs e editores
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Sistemas operacionais
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Backups
# =============================================================================
backups/*.sql
backups/*.sql.gz
backups/*.dump

# =============================================================================
# Profiling
# =============================================================================
*.prof
