# =============================================================================
# SafraLog — .env.example
# Copie para .env e ajuste os valores
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production-min-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_INTERNAL_IPS=127.0.0.1

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=safralog
POSTGRES_USER=safralog
POSTGRES_PASSWORD=safralog_dev_password

DATABASE_URL=postgresql://safralog:safralog_dev_password@postgres:5432/safralog

# -----------------------------------------------------------------------------
# REDIS / CACHE / CELERY
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CACHE_URL=redis://redis:6379/3

# -----------------------------------------------------------------------------
# EMAIL
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@safralog.com.br
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=SafraLog <noreply@safralog.com.br>

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------
# local | s3
STORAGE_BACKEND=local
MEDIA_ROOT=/app/media

# AWS S3 (produção)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=sa-east-1
AWS_S3_CUSTOM_DOMAIN=

# -----------------------------------------------------------------------------
# SEGURANÇA (produção)
# -----------------------------------------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------
APP_NAME=SafraLog
APP_URL=http://localhost:8000
APP_VERSION=1.0.0
TIMEZONE=America/Sao_Paulo

# -----------------------------------------------------------------------------
# CELERY / FLOWER
# -----------------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=admin123
FLOWER_PORT=5555

# -----------------------------------------------------------------------------
# GUNICORN
# -----------------------------------------------------------------------------
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# -----------------------------------------------------------------------------
# SENTRY (produção — opcional)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG
